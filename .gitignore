# Dependencies
node_modules/
/.pnp
.pnp.js

# Next.js
/.next/
/out/

# Production build
/build

# Env files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# SQLite database (local dev only — never commit)
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm

# Local uploads — preserve directory structure but not user files
public/uploads/**
!public/uploads/**/.gitkeep
!public/uploads/.gitkeep

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
*.pem

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts
